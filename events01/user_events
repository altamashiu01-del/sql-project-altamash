DROP TABLE IF EXISTS user_events;

CREATE TABLE user_events (
    event_id INT,
    user_id INT,
    event_type TEXT,
    event_date TEXT,
    product_id INT,
    amount NUMERIC,
    traffic_source TEXT
);




SELECT * FROM user_events
ORDER BY event_id;



SELECT 
    event_type,
    COUNT(*) AS events_count
FROM user_events
GROUP BY event_type;



SELECT
    COUNT(*) FILTER (WHERE event_type = 'page_view') AS views,
    COUNT(*) FILTER (WHERE event_type = 'add_to_cart') AS carts,
    COUNT(*) FILTER (WHERE event_type = 'purchase') AS purchases,

    ROUND(
        COUNT(*) FILTER (WHERE event_type = 'add_to_cart') * 100.0 /
        COUNT(*) FILTER (WHERE event_type = 'page_view'),
    2) AS cart_rate,

    ROUND(
        COUNT(*) FILTER (WHERE event_type = 'purchase') * 100.0 /
        COUNT(*) FILTER (WHERE event_type = 'add_to_cart'),
    2) AS cart_to_purchase_rate

FROM user_events;